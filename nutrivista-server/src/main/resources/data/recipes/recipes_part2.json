      {"name": "生抽", "amount": "20", "unit": "ml", "food_id": null},
      {"name": "番茄酱", "amount": "30", "unit": "g", "food_id": null},
      {"name": "淀粉", "amount": "80", "unit": "g", "food_id": null},
      {"name": "葱姜蒜", "amount": "25", "unit": "g", "food_id": null},
